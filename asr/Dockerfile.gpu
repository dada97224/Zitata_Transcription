FROM nvidia/cuda:12.4.1-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    python3 python3-pip python3-dev \
    ffmpeg libsndfile1 git sox && \
    rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3 /usr/bin/python
RUN python3 -m pip install --upgrade pip setuptools wheel

WORKDIR /app
RUN mkdir -p /app/downloads

COPY requirements.txt .
# NeMo installe souvent torch (CPU) : on installe d’abord les deps, puis on force PyTorch CUDA en dernier
RUN pip install --no-cache-dir "numpy>=1.22" "typing_extensions>=4.8.0"
RUN pip install --no-cache-dir -r requirements.txt
RUN pip install --no-cache-dir --force-reinstall torch torchaudio --index-url https://download.pytorch.org/whl/cu121

COPY . .

ENV ASR_MODE=parakeet
ENV ASR_MODEL=Archime/parakeet-tdt-0.6b-v3-fr-tv-media
ENV NVIDIA_VISIBLE_DEVICES=all

EXPOSE 8001
CMD ["python", "-m", "uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8001", "--timeout-keep-alive", "3600"]
