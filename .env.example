YOUTUBE_API_KEY=your_youtube_data_v3_key
YOUTUBE_CHANNEL_ID=your_channel_id
DATABASE_URL=postgres://zitata:zitata_dev@localhost:5432/zitata
REDIS_URL=redis://localhost:6379
NEXT_PUBLIC_API_URL=http://localhost:3001

# ASR — service local ou distant (Windows GPU, Mac M4, etc.)
ASR_URL=http://localhost:8001

# ASR mode : auto (détecte GPU), parakeet (force), mock (simulé)
ASR_MODE=auto
ASR_MODEL=Archime/parakeet-tdt-0.6b-v3-fr-tv-media

# Cookies YouTube (optionnel, sinon --cookies-from-browser chrome)
# YT_COOKIES_PATH=./cookies/youtube_cookies.txt
